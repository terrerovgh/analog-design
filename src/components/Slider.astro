---
/**
 * Slider — instrument-style range input with stepped tick marks
 * and a numeric readout. Wraps native <input type="range">.
 *
 * @example
 *   <Slider id="gain" label="GAIN" min={0} max={100} step={5} value={60} unit="%" />
 *   <Slider id="freq" label="FREQ" min={20} max={20000} value={440} unit="Hz" ticks={5} />
 */

interface Props {
  id: string;
  label: string;
  name?: string;
  min?: number;
  max?: number;
  step?: number;
  value?: number;
  unit?: string;
  ticks?: number;
  disabled?: boolean;
  signal?: boolean;
}

const {
  id,
  label,
  name = id,
  min = 0,
  max = 100,
  step = 1,
  value = Math.round((min + max) / 2),
  unit = '',
  ticks = 9,
  disabled = false,
  signal = false,
} = Astro.props;

const tickArray = Array.from({ length: ticks });
---

<div class:list={['ad-slider', signal && 'ad-slider--signal', disabled && 'ad-slider--disabled']}>
  <div class="ad-slider__head">
    <label class="ad-slider__label" for={id}>{label}</label>
    <output class="ad-slider__value" for={id} data-readout>
      {value}<span class="ad-slider__unit">{unit}</span>
    </output>
  </div>

  <div class="ad-slider__rail">
    <div class="ad-slider__ticks" aria-hidden="true">
      {tickArray.map((_, i) => (
        <span class:list={['ad-slider__tick', (i % 2 === 0) && 'ad-slider__tick--major']}></span>
      ))}
    </div>
    <input
      class="ad-slider__input"
      id={id}
      name={name}
      type="range"
      min={min}
      max={max}
      step={step}
      value={value}
      disabled={disabled}
      data-min={min}
      data-max={max}
      data-unit={unit}
    />
    <div class="ad-slider__bounds" aria-hidden="true">
      <span>{min}{unit}</span>
      <span>{max}{unit}</span>
    </div>
  </div>
</div>

<script>
  const sliders = document.querySelectorAll<HTMLDivElement>('.ad-slider');
  for (const root of sliders) {
    const input = root.querySelector<HTMLInputElement>('.ad-slider__input');
    const readout = root.querySelector<HTMLOutputElement>('[data-readout]');
    if (!input || !readout) continue;
    const unit = input.dataset.unit ?? '';
    const sync = () => {
      readout.innerHTML = `${input.value}<span class="ad-slider__unit">${unit}</span>`;
      const min = Number(input.min || 0);
      const max = Number(input.max || 100);
      const pct = ((Number(input.value) - min) / (max - min || 1)) * 100;
      root.style.setProperty('--ad-slider-pct', `${pct}%`);
    };
    input.addEventListener('input', sync);
    sync();
  }
</script>

<style>
  .ad-slider {
    --ad-slider-pct: 50%;
    display: flex;
    flex-direction: column;
    gap: var(--ad-space-2);
    color: var(--ad-ink);
    font-family: var(--ad-font-mono);
    width: 100%;
  }

  .ad-slider__head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--ad-space-3);
  }

  .ad-slider__label {
    font-size: var(--ad-text-2xs);
    font-weight: var(--ad-weight-bold);
    letter-spacing: var(--ad-track-wide);
    text-transform: uppercase;
    color: var(--ad-ink);
    cursor: pointer;
  }

  .ad-slider__value {
    font-size: var(--ad-text-md);
    font-weight: var(--ad-weight-bold);
    letter-spacing: var(--ad-track-tight);
    font-variant-numeric: tabular-nums;
  }

  .ad-slider__unit {
    margin-left: 4px;
    font-size: var(--ad-text-2xs);
    letter-spacing: var(--ad-track-wide);
    text-transform: uppercase;
    color: var(--ad-muted);
  }

  .ad-slider__rail {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--ad-space-2) 0;
  }

  .ad-slider__ticks {
    position: absolute;
    top: 6px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: space-between;
    pointer-events: none;
  }

  .ad-slider__tick {
    width: 1px;
    height: 6px;
    background: var(--ad-graphite-5);
  }

  .ad-slider__tick--major {
    height: 10px;
    background: var(--ad-ink);
  }

  .ad-slider__input {
    position: relative;
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 22px;
    background: transparent;
    margin: 0;
    cursor: pointer;
  }

  .ad-slider__input:focus { outline: none; }

  /* Track */
  .ad-slider__input::-webkit-slider-runnable-track {
    height: 4px;
    background: linear-gradient(
      to right,
      var(--ad-ink) 0 var(--ad-slider-pct),
      var(--ad-graphite-3) var(--ad-slider-pct) 100%
    );
    border: var(--ad-border-hair) solid var(--ad-ink);
  }

  .ad-slider__input::-moz-range-track {
    height: 4px;
    background: var(--ad-graphite-3);
    border: var(--ad-border-hair) solid var(--ad-ink);
  }

  .ad-slider__input::-moz-range-progress {
    height: 4px;
    background: var(--ad-ink);
  }

  /* Thumb */
  .ad-slider__input::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 14px;
    height: 22px;
    margin-top: -10px;
    background: var(--ad-elevated);
    border: var(--ad-border-bold) solid var(--ad-ink);
    cursor: grab;
  }

  .ad-slider__input::-moz-range-thumb {
    width: 14px;
    height: 22px;
    background: var(--ad-elevated);
    border: var(--ad-border-bold) solid var(--ad-ink);
    border-radius: 0;
    cursor: grab;
  }

  .ad-slider--signal .ad-slider__input::-webkit-slider-thumb {
    background: var(--ad-signal);
  }
  .ad-slider--signal .ad-slider__input::-moz-range-thumb {
    background: var(--ad-signal);
  }

  .ad-slider__input:focus-visible::-webkit-slider-thumb {
    outline: var(--ad-border-bold) solid var(--ad-ink);
    outline-offset: 2px;
  }

  .ad-slider__bounds {
    display: flex;
    justify-content: space-between;
    font-size: var(--ad-text-2xs);
    letter-spacing: var(--ad-track-wide);
    text-transform: uppercase;
    color: var(--ad-muted);
  }

  .ad-slider--disabled {
    opacity: 0.5;
    pointer-events: none;
  }
</style>
