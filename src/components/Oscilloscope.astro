---
/**
 * Oscilloscope — animated waveform display.
 *
 * Pure SVG. The wave path is generated server-side from the
 * chosen `wave` type. The animation is a CSS stroke-dashoffset
 * loop combined with a sweeping scan beam over a phosphor grid.
 *
 * @example
 *   <Oscilloscope wave="sine" />
 *   <Oscilloscope wave="square" frequency={3} amplitude={0.7} label="CH-01" />
 *   <Oscilloscope wave="sawtooth" critical paused />
 */

type Wave = 'sine' | 'square' | 'sawtooth' | 'triangle' | 'noise';

interface Props {
  wave?: Wave;
  width?: number;
  height?: number;
  /** Cycles across the viewport */
  frequency?: number;
  /** 0..1 — fraction of half-height */
  amplitude?: number;
  label?: string;
  critical?: boolean;
  paused?: boolean;
  /** Grid divisions (cols × rows) */
  grid?: [number, number];
}

const {
  wave = 'sine',
  width = 320,
  height = 120,
  frequency = 2,
  amplitude = 0.6,
  label,
  critical = false,
  paused = false,
  grid = [10, 4],
} = Astro.props;

const cy = height / 2;
const amp = (height / 2) * Math.max(0, Math.min(1, amplitude));

// Sample 240 points for smoothness
const samples = 240;
const dx = width / samples;

const buildPath = (): string => {
  const pts: string[] = [];
  for (let i = 0; i <= samples; i++) {
    const x = i * dx;
    const t = (i / samples) * frequency * Math.PI * 2;
    let y = 0;
    switch (wave) {
      case 'sine':     y = Math.sin(t); break;
      case 'square':   y = Math.sin(t) >= 0 ? 1 : -1; break;
      case 'sawtooth': y = (((i / samples) * frequency) % 1) * 2 - 1; break;
      case 'triangle': {
        const p = ((i / samples) * frequency) % 1;
        y = p < 0.5 ? p * 4 - 1 : 3 - p * 4;
        break;
      }
      case 'noise':    y = (Math.sin(t * 7) + Math.sin(t * 13.7) + Math.sin(t * 3.1)) / 3; break;
    }
    const yPos = cy - y * amp;
    pts.push(`${i === 0 ? 'M' : 'L'} ${x.toFixed(2)} ${yPos.toFixed(2)}`);
  }
  return pts.join(' ');
};

const pathD = buildPath();
const [cols, rows] = grid;
---

<figure class:list={['ad-osc', critical && 'ad-osc--critical', paused && 'ad-osc--paused']}>
  {label && (
    <figcaption class="ad-osc__head">
      <span class="ad-osc__label">{label}</span>
      <span class="ad-osc__meta">{wave.toUpperCase()} · {frequency}Hz · A={amplitude.toFixed(2)}</span>
    </figcaption>
  )}

  <div class="ad-osc__screen">
    <svg
      width={width}
      height={height}
      viewBox={`0 0 ${width} ${height}`}
      preserveAspectRatio="none"
      role="img"
      aria-label={`${wave} waveform`}
    >
      {/* phosphor grid */}
      {Array.from({ length: cols + 1 }).map((_, i) => {
        const x = (i / cols) * width;
        return <line x1={x} y1={0} x2={x} y2={height}
          stroke="var(--ad-graphite-3)" stroke-width="0.5" stroke-dasharray={i === cols / 2 ? '0' : '1 3'} />;
      })}
      {Array.from({ length: rows + 1 }).map((_, i) => {
        const y = (i / rows) * height;
        return <line x1={0} y1={y} x2={width} y2={y}
          stroke="var(--ad-graphite-3)" stroke-width="0.5" stroke-dasharray={i === rows / 2 ? '0' : '1 3'} />;
      })}

      {/* the trace itself — drawn twice for "sweep" effect */}
      <path d={pathD} fill="none" stroke="currentColor" stroke-width="1.2"
        class="ad-osc__trace" style={`--ad-stream-length:${width};`} />

      {/* corner ticks */}
      <line x1={0}     y1={0}      x2={6}      y2={0}     stroke="currentColor" />
      <line x1={0}     y1={0}      x2={0}      y2={6}     stroke="currentColor" />
      <line x1={width} y1={0}      x2={width-6} y2={0}    stroke="currentColor" />
      <line x1={width} y1={0}      x2={width}  y2={6}     stroke="currentColor" />
      <line x1={0}     y1={height} x2={6}      y2={height} stroke="currentColor" />
      <line x1={0}     y1={height} x2={0}      y2={height-6} stroke="currentColor" />
      <line x1={width} y1={height} x2={width-6} y2={height} stroke="currentColor" />
      <line x1={width} y1={height} x2={width}  y2={height-6} stroke="currentColor" />
    </svg>

    {/* scan beam */}
    <div class="ad-osc__beam" aria-hidden="true"></div>
  </div>
</figure>

<style>
  .ad-osc {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    margin: 0;
    color: var(--ad-ink);
    font-family: var(--ad-font-mono);
  }

  .ad-osc--critical { color: var(--ad-signal); }

  .ad-osc__head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--ad-space-3);
  }

  .ad-osc__label {
    font-size: var(--ad-text-2xs);
    font-weight: var(--ad-weight-bold);
    letter-spacing: var(--ad-track-wide);
    text-transform: uppercase;
  }

  .ad-osc__meta {
    font-size: var(--ad-text-2xs);
    letter-spacing: var(--ad-track-wide);
    text-transform: uppercase;
    color: var(--ad-muted);
  }

  .ad-osc__screen {
    position: relative;
    border: var(--ad-border-hair) solid var(--ad-ink);
    overflow: hidden;
    background: var(--ad-paper);
  }

  .ad-osc__screen svg {
    display: block;
    shape-rendering: geometricPrecision;
  }

  .ad-osc__trace {
    stroke-dasharray: var(--ad-stream-length, 320);
    stroke-dashoffset: var(--ad-stream-length, 320);
    animation: ad-stream var(--ad-dur-orbit) var(--ad-ease-step24) infinite;
  }

  .ad-osc__beam {
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 100%;
    background: currentColor;
    opacity: 0.55;
    animation: ad-scan var(--ad-dur-scan) var(--ad-ease-step24) infinite;
  }

  .ad-osc--paused .ad-osc__trace,
  .ad-osc--paused .ad-osc__beam {
    animation-play-state: paused;
  }
</style>
