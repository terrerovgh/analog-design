---
/**
 * RotaryKnob — circular value indicator with tick marks.
 *
 * Pure SVG, no JS. The pointer rotates between -135° (min)
 * and +135° (max) — leaving a 90° dead zone at the bottom,
 * like a real analog potentiometer. Use `live` for slow
 * stepped autonomous rotation (decorative).
 *
 * @example
 *   <RotaryKnob value={62} label="GAIN" />
 *   <RotaryKnob value={3}  max={11} label="VOLUME" unit="" />
 *   <RotaryKnob value={88} label="DRIVE" critical />
 *   <RotaryKnob value={0}  label="ORBIT" live />
 */

interface Props {
  value: number;
  min?: number;
  max?: number;
  label?: string;
  unit?: string;
  size?: number;
  /** Number of tick marks around the dial */
  ticks?: number;
  /** Apply Signal accent (e.g. driving past safe range) */
  critical?: boolean;
  /** Decorative: rotate the pointer continuously in steps */
  live?: boolean;
}

const {
  value,
  min = 0,
  max = 100,
  label,
  unit = '%',
  size = 96,
  ticks = 13,
  critical = false,
  live = false,
} = Astro.props;

const c = size / 2;
const r = size / 2 - 4;
const innerR = r - 6;

// Map value to angle: -135° (min) → +135° (max)
const pct = Math.max(0, Math.min(1, (value - min) / (max - min || 1)));
const angle = -135 + pct * 270;

// Tick positions
const tickAngles = Array.from({ length: ticks }).map((_, i) => {
  return -135 + (i / (ticks - 1)) * 270;
});

const display = unit === '%'
  ? `${Math.round(pct * 100)}%`
  : `${value}${unit ? ' ' + unit : ''}`;
---

<figure class:list={['ad-knob', critical && 'ad-knob--critical']}>
  <svg
    width={size}
    height={size}
    viewBox={`0 0 ${size} ${size}`}
    role="img"
    aria-label={`${label ?? 'knob'} ${display}`}
  >
    {/* outer ring */}
    <circle cx={c} cy={c} r={r} fill="var(--ad-paper)" stroke="currentColor" stroke-width="1.5" />
    {/* inner cap */}
    <circle cx={c} cy={c} r={innerR} fill="var(--ad-paper)" stroke="currentColor" stroke-width="1" />

    {/* tick marks */}
    {tickAngles.map((a, i) => {
      const rad = (a - 90) * Math.PI / 180;
      const isMajor = i === 0 || i === ticks - 1 || i === Math.floor(ticks / 2);
      const len = isMajor ? 6 : 3;
      const x1 = c + Math.cos(rad) * (r + 2);
      const y1 = c + Math.sin(rad) * (r + 2);
      const x2 = c + Math.cos(rad) * (r + 2 + len);
      const y2 = c + Math.sin(rad) * (r + 2 + len);
      return (
        <line x1={x1} y1={y1} x2={x2} y2={y2}
          stroke="currentColor" stroke-width={isMajor ? 1.5 : 0.75} />
      );
    })}

    {/* pointer group — rotated */}
    <g
      class:list={['ad-knob__pointer', live && 'ad-knob__pointer--live']}
      style={`transform-origin:${c}px ${c}px; transform:rotate(${angle}deg);`}
    >
      <line x1={c} y1={c} x2={c} y2={c - innerR + 4}
        stroke="currentColor" stroke-width="2" stroke-linecap="square" />
      <circle cx={c} cy={c} r="3" fill="currentColor" />
    </g>
  </svg>

  {(label || display) && (
    <figcaption class="ad-knob__readout">
      {label && <span class="ad-knob__label">{label}</span>}
      <span class="ad-knob__value">{display}</span>
    </figcaption>
  )}
</figure>

<style>
  .ad-knob {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: var(--ad-space-2);
    margin: 0;
    color: var(--ad-ink);
    font-family: var(--ad-font-mono);
  }

  .ad-knob--critical { color: var(--ad-signal); }

  .ad-knob svg {
    display: block;
    shape-rendering: geometricPrecision;
    overflow: visible;
  }

  .ad-knob__pointer {
    transition: transform var(--ad-dur-tick) var(--ad-ease-step12);
  }

  .ad-knob__pointer--live {
    animation: ad-orbit var(--ad-dur-orbit) var(--ad-ease-step24) infinite;
  }

  .ad-knob__readout {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    line-height: 1;
  }

  .ad-knob__label {
    font-size: var(--ad-text-2xs);
    font-weight: var(--ad-weight-bold);
    letter-spacing: var(--ad-track-wide);
    text-transform: uppercase;
    color: var(--ad-muted);
  }

  .ad-knob__value {
    font-size: var(--ad-text-sm);
    font-weight: var(--ad-weight-bold);
    font-variant-numeric: tabular-nums;
    letter-spacing: var(--ad-track-tight);
  }
</style>
